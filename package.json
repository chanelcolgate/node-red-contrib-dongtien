{
  "name": "node-red-contrib-dongtien",
  "version": "0.0.1",
  "description": "A shared node for electricity meters",
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@types/node-red": "^1.3.5",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.1"
  },
  "scripts": {
    "build": "rm -r dist && npm run build:cjs",
    "build:cjs": "tsc --module commonjs --outDir dist && cp src/*.html dist/",
